# Copy to .env for local overrides (optional). Production: set these in the host dashboard.

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-api.onrender.com,localhost,127.0.0.1

# Persistent database (required on Render / any ephemeral filesystem host).
# After creating a Postgres service, paste its Internal Database URL here.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
#
# Local Postgres without SSL:
# DATABASE_SSL_REQUIRE=false

# Optional: comma-separated extra CORS origins
# CORS_ALLOWED_ORIGINS=https://your-frontend.netlify.app

# Build: set to false to skip seed_demo_data on deploy
# SEED_DEMO_DATA=true
